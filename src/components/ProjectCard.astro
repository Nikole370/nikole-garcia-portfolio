---
import type { Project } from "../data/projects";
import { withBase } from "../config/site";

interface Props {
  project: Project;
  /** Load the first card's image eagerly for LCP. */
  eager?: boolean;
}

const { project, eager = false } = Astro.props;
const detailHref = withBase(`/projects/${project.slug}/`);
---

<article class="card project-card">
  <a class="project-card__media" href={detailHref} tabindex="-1" aria-hidden="true">
    <img
      src={withBase(project.cover.src)}
      alt=""
      width={project.cover.width}
      height={project.cover.height}
      loading={eager ? "eager" : "lazy"}
      decoding="async"
    />
  </a>

  <div class="project-card__body">
    <div class="project-card__chips">
      <span class={`chip ${project.status === "Published" ? "chip--accent" : "chip--green"}`}>
        {project.status}
      </span>
      <span class="chip">{project.authorship.split("—")[0].trim()}</span>
    </div>

    <h3 class="project-card__title">
      <a href={detailHref}>{project.title}</a>
    </h3>

    <p class="project-card__tagline">{project.tagline}</p>

    {project.notice && <p class="project-card__notice">{project.notice}</p>}

    <ul class="project-card__stack" aria-label="Main tools">
      {project.stack.slice(0, 5).map((tool) => <li>{tool}</li>)}
    </ul>

    <div class="project-card__links">
      <a class="btn btn--primary" href={detailHref}>Read case study</a>
      {
        project.links
          .filter((l) => l.primary && !l.href.startsWith("mailto:"))
          .map((l) => (
            <a
              class="btn btn--ghost"
              href={l.href}
              rel="noopener noreferrer"
              target="_blank"
            >
              {l.label}
              <span class="visually-hidden"> (opens in a new tab)</span>
            </a>
          ))
      }
    </div>
  </div>
</article>

<style>
  .project-card {
    display: grid;
  }

  @media (min-width: 780px) {
    .project-card {
      grid-template-columns: minmax(0, 5fr) minmax(0, 4fr);
      align-items: stretch;
    }
  }

  .project-card__media {
    display: block;
    background: var(--bg-inset);
    border-bottom: 1px solid var(--border);
  }

  @media (min-width: 780px) {
    .project-card__media {
      border-bottom: 0;
      border-right: 1px solid var(--border);
    }
  }

  .project-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-card__body {
    padding: clamp(1.25rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .project-card__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .project-card__title {
    margin: 0;
    font-size: var(--text-lg);
  }

  .project-card__title a {
    color: var(--text);
    text-decoration: none;
  }

  .project-card__title a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  .project-card__tagline {
    color: var(--text-muted);
    margin: 0;
  }

  .project-card__notice {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--accent-2);
  }

  .project-card__stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-3);
    padding: 0;
    margin: 0;
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .project-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: auto;
    padding-top: var(--space-2);
  }
</style>
