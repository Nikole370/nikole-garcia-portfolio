---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site, withBase } from "../config/site";

interface Props {
  title: string;
  description?: string;
  /** Path of this page without base, e.g. "/projects/ecolima/". */
  path?: string;
  /** Extra JSON-LD to inject (already-built object). */
  structuredData?: Record<string, unknown>;
}

const {
  title,
  description = site.description,
  path = "/",
  structuredData,
} = Astro.props;

const canonical = new URL(withBase(path), site.url).href;
const ogImage = new URL(withBase("/og.png"), site.url).href;

const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: site.name,
  jobTitle: site.role,
  email: `mailto:${site.links.email}`,
  address: { "@type": "PostalAddress", addressLocality: "Lima", addressCountry: "PE" },
  url: new URL(withBase("/"), site.url).href,
  sameAs: [site.links.github, site.links.linkedin, site.links.tableau],
  knowsAbout: [
    "Data Analytics",
    "Business Intelligence",
    "SQL",
    "Python",
    "Tableau",
    "Data Engineering",
  ],
};
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="sitemap" href={withBase("/sitemap-index.xml")} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
    {
      structuredData && (
        <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
      )
    }

    <!-- Theme: applied before paint to avoid flash. Falls back to system preference. -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var theme =
            stored === "light" || stored === "dark"
              ? stored
              : window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.setAttribute("data-theme", theme);
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
    <meta name="color-scheme" content="light dark" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
